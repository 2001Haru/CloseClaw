# Copy this file to .env and fill real values where needed.

# Built image tag used by docker-compose
CLOSECLAW_IMAGE=closeclaw:local

# Build extras for optional dependencies
# Examples:
# [providers]
# [providers,telegram,discord,whatsapp,qq]
INSTALL_EXTRAS=[providers]

# Host port mapped to container :9000 (useful for Feishu webhook mode)
GATEWAY_PORT=9000

# Healthcheck tuning
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=20s

# Resource guidance (adjust to your host capacity)
GATEWAY_MEM_LIMIT=1g
GATEWAY_CPUS=1.00
CLI_MEM_LIMIT=768m
CLI_CPUS=1.00

# Provider/channel secrets can be injected from here if your config.yaml uses ${ENV_VAR} placeholders.
# OPENAI_API_KEY=
# TELEGRAM_BOT_TOKEN=
# FEISHU_TOKEN=
# FEISHU_WEBHOOK=
# DISCORD_BOT_TOKEN=
# QQ_APP_ID=
# QQ_APP_SECRET=
